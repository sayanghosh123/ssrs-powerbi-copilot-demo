<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>

  <!-- ============================================================
       DATASET: Inline SQL — no shared dataset
       SQL: SELECT TerritoryID, Name, [Group], SalesYTD, SalesLastYear
            FROM Sales.SalesTerritory
       SSRS Features demonstrated:
         - =RowNumber(Nothing)          → Power BI: Index column
         - =RowNumber(Nothing) Mod 2    → Power BI: Conditional formatting
         - =IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")
                                        → Power BI: Alternating row colour via conditional formatting
       ============================================================ -->
  <DataSources>
    <DataSource Name="Adventure_Works">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=(local);Initial Catalog=AdventureWorks2019</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>6a05bd9c-9606-43c3-8fb1-f94e2f26e4dd</rd:DataSourceID>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="SalesTerritory">
      <Query>
        <DataSourceName>Adventure_Works</DataSourceName>
        <CommandText>SELECT TerritoryID, Name, [Group], SalesYTD, SalesLastYear
FROM Sales.SalesTerritory</CommandText>
      </Query>
      <Fields>
        <Field Name="TerritoryID"><DataField>TerritoryID</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="Name"><DataField>Name</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Group"><DataField>Group</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SalesYTD"><DataField>SalesYTD</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="SalesLastYear"><DataField>SalesLastYear</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>

  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Tablix Name="Tablix1">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>1.00in</Width></TablixColumn>  <!-- Row# -->
                <TablixColumn><Width>1.00in</Width></TablixColumn>  <!-- Mod2 -->
                <TablixColumn><Width>1.00in</Width></TablixColumn>  <!-- Group -->
                <TablixColumn><Width>1.50in</Width></TablixColumn>  <!-- Name -->
                <TablixColumn><Width>1.51in</Width></TablixColumn>  <!-- Sales YTD -->
                <TablixColumn><Width>1.95in</Width></TablixColumn>  <!-- Sales Last Year -->
              </TablixColumns>
              <TablixRows>
                <!-- Header Row -->
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="hdrRow"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Row</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="hdrMod"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Mod 2</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="hdrGroup"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Group</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="hdrName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Name</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="hdrSalesYTD"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales YTD</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="hdrSalesLY"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales Last Year</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>Silver</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <!-- Data Row with alternating colour SSRS expression -->
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="fldRow"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber(Nothing)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="fldMod"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber(Nothing) Mod 2</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="fldGroup"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Group.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="fldName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Name.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="fldSalesYTD"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SalesYTD.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Format>C0</Format><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="fldSalesLY"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SalesLastYear.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Format>C0</Format><BackgroundColor>=IIf(RowNumber(Nothing) Mod 2,"OldLace","Ivory")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><TablixHeader><Size>0in</Size></TablixHeader></TablixMember>
                <TablixMember><Group Name="Detail"/></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/>
              </TablixMembers>
            </TablixColumnHierarchy>
            <DataSetName>SalesTerritory</DataSetName>
          </Tablix>
        </ReportItems>
        <Height>2in</Height>
      </Body>
      <Width>8in</Width>
      <Page>
        <PageHeight>8.5in</PageHeight>
        <PageWidth>11in</PageWidth>
        <LeftMargin>1in</LeftMargin><RightMargin>1in</RightMargin>
        <TopMargin>1in</TopMargin><BottomMargin>1in</BottomMargin>
      </Page>
    </ReportSection>
  </ReportSections>
  <Language>en-US</Language>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
